  "description": "PHP backend for transaction dashboard application",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.0",
    "mongodb/mongodb": "^2.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true
    }
  }
}
